# Compiled binaries / shared objects
*.exe
*.exe~
*.dll
*.so
*.dylib

# The psdns binary built via `go build ./cmd/psdns` (repo root only — does NOT
# match the cmd/psdns/ source directory).
/psdns
/psdns-*

# Release archives produced by scripts/build-release.sh
/dist/

# Wails GUI build output and generated JS bindings (wails build regenerates them)
/cmd/psdns-gui/build/bin/
/cmd/psdns-gui/frontend/wailsjs/

# Test binaries built with `go test -c`
*.test

# Coverage / profiling output (scripts/bench.sh -cpuprofile writes *.prof)
*.out
coverage.*
*.prof

# Go workspace files
go.work
go.work.sum

# OS / editor cruft
.DS_Store
*~
